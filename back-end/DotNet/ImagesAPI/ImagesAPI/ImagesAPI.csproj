<Project Sdk="Microsoft.NET.Sdk.Web">

	<PropertyGroup>
		<TargetFramework>net8.0</TargetFramework>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
	</PropertyGroup>

	<ItemGroup>
		<Reference Include="ImagesProcessor">
			<HintPath>$(SolutionDir)..\..\Shared\Lib\x64\$(Configuration)\ImagesProcessor.dll</HintPath>
		</Reference>
		<None Include="$(SolutionDir)..\..\Shared\Lib\x64\$(Configuration)\ImagesProcessor.dll">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</None>
	</ItemGroup>

	<Target Name="CopyDependencies" AfterTargets="Build">
		<Copy SourceFiles="$(SolutionDir)..\..\Shared\Lib\x64\Debug\ImagesProcessor.dll" DestinationFolder="$(OutDir)" />
		<ItemGroup>
			<OpenCvDlls Include="$(SolutionDir)..\..\Shared\Lib\vc16\bin\*.dll" />
		</ItemGroup>
		<Copy
			SourceFiles="@(OpenCvDlls)"
			DestinationFolder="$(OutDir)" />
	</Target>

	<Target Name="LogResolvedPaths" BeforeTargets="Build">
		<Message Text="Resolved DLL Path: $(SolutionDir)..\..\Shared\Lib\x64\$(Configuration)\ImagesProcessor.dll" Importance="High" />
	</Target>

	<ItemGroup>
		<PackageReference Include="Google.Apis" Version="1.68.0" />
		<PackageReference Include="Google.Apis.Auth" Version="1.68.0" />
		<PackageReference Include="Google.Apis.Drive.v3" Version="1.68.0.3608" />
		<PackageReference Include="MongoDB.Driver" Version="3.1.0" />
		<PackageReference Include="SkiaSharp" Version="3.116.1" />
		<PackageReference Include="Swashbuckle.AspNetCore" Version="6.6.2" />
		<PackageReference Include="System.Drawing.Common" Version="9.0.0" />
	</ItemGroup>

</Project>
